{
  "name": "firewall-wallet",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "test:contracts": "cd packages/contracts && forge test -q --no-match-path 'test/fork/*.sol'",
    "test:contracts:full": "cd packages/contracts && forge test",
    "smoke:contracts": "cd packages/contracts && forge test --match-path 'test/smoke/*.sol'",
    "security:static": "./scripts/security-static-check.sh",
    "bot:queue:once": "cd packages/contracts && forge script script/RunQueueRelayer.s.sol:RunQueueRelayer --rpc-url \"$BASE_RPC_URL\" --broadcast -vv",
    "bot:queue:loop": "while true; do npm run bot:queue:once; sleep ${QUEUE_BOT_INTERVAL_SECONDS:-20}; done",
    "integrity:check": "./scripts/integrity.sh check",
    "integrity:update": "./scripts/integrity.sh update"
  }
}
